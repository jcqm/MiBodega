<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.listitem.ListItemCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


        <TextView
            android:id="@+id/txtLista_FiadosNombre"
            android:layout_width="120dp"
            android:layout_height="30dp"
            android:layout_marginStart="25dp"
            android:layout_marginTop="10dp"
            android:text="Nombre"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/txtLista_FiadosFechaFiado"
            android:layout_width="120dp"
            android:layout_height="30dp"
            android:layout_marginStart="25dp"
            android:layout_marginTop="40dp"
            android:text="Fecha Fiado"
            android:textSize="18sp" />


        <TextView
            android:id="@+id/txtLista_FiadosDeuda"
            android:layout_width="100dp"
            android:layout_height="30dp"
            android:layout_alignParentLeft="false"
            android:layout_marginStart="50dp"
            android:layout_marginTop="10dp"
            android:layout_toEndOf="@id/txtLista_FiadosNombre"
            android:text="Deuda"
            android:textAlignment="center"
            android:textSize="20dp" />

        <TextView
            android:id="@+id/txtLista_FiadoEstado"
            android:layout_width="120dp"
            android:layout_height="30dp"
            android:layout_marginStart="50dp"
            android:layout_toEndOf="@id/txtLista_FiadosNombre"
            android:layout_marginTop="40dp"
            android:text="Estado"
            android:textSize="18sp" />
    </RelativeLayout>

</com.google.android.material.listitem.ListItemCardView>