<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.listitem.ListItemCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp">

        <TextView
            android:id="@+id/tvTopPosicion"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="#1"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@color/bluegray"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true" />

        <TextView
            android:id="@+id/tvTopNombreProducto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Producto"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginStart="12dp"
            android:layout_toEndOf="@id/tvTopPosicion" />

        <TextView
            android:id="@+id/tvTopVecesVendido"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vendido 0 veces"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_below="@id/tvTopNombreProducto"
            android:layout_marginStart="12dp"
            android:layout_toEndOf="@id/tvTopPosicion"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvTopTotalGenerado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="S/ 0.00"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />

    </RelativeLayout>
</com.google.android.material.listitem.ListItemCardView>