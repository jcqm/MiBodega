<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.AgregarProducto">

    <androidx.cardview.widget.CardView
        android:layout_marginTop="28dp"
        android:id="@+id/cardTitulo"
        android:layout_width="411dp"
        android:layout_height="50dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AGREGAR PRODUCTO"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginLeft="24dp"
        android:layout_marginTop="60dp"
        android:layout_marginRight="24dp"
        android:orientation="vertical">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:layout_marginTop="20dp"
            android:id="@+id/btnFotoProducto"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:textAlignment="center"
            app:icon="@drawable/baseline_camera_alt_24"
            app:iconGravity="textStart"
            app:iconSize="50dp" />

        <EditText
            android:id="@+id/txtNombreProducto"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:ems="10"
            android:hint="Nombre del producto"
            android:inputType="text" />

        <!-- Fila con Spinner de categorias y boton para gestionar categorias -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Spinner que ahora carga las categorias desde la base de datos -->
            <Spinner
                android:id="@+id/spCategoria"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ems="10" />

            <!-- NUEVO: Boton pequeño para ir a gestionar (agregar/editar/eliminar) categorias -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGestionarCategorias"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Gestionar"
                android:textSize="11sp"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="77dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/txtPrecio"
                android:layout_width="wrap_content"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:ems="10"
                android:hint="Precio Venta (S/)"
                android:inputType="number" />

            <EditText
                android:id="@+id/txtStock"
                android:layout_width="wrap_content"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:ems="10"
                android:hint="Stock inicial"
                android:inputType="number" />
        </LinearLayout>

        <Button
            android:id="@+id/GuardarProducto"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="Guardar Producto"
            android:layout_marginBottom="10dp"
            android:textSize="25dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>